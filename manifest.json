{
    "id": "subsonic-client",
    "name": "Subsonic",
    "version": "0.1.0",
    "minNoctaliaVersion": "3.6.0",
    "author": "Eros404",
    "license": "MIT",
    "repository": "https://github.com/eros404/noctalia-subsonic-client",
    "description": "Listen your music hosted on a subsonic compatible server. Provides action for the Noctalia launcher.",
    "entryPoints": {
        "main": "Main.qml",
        "launcherProvider": "LauncherProvider.qml",
        "settings": "Settings.qml"
    },
    "dependencies": {
        "plugins": []
    },
    "metadata": {
        "commandPrefix": "sonic",
        "defaultSettings": {
            "serverUrl": "",
            "userName": "",
            "password": "",
            "searchArtists": 3,
            "searchAlbums": 3,
            "searchSongs": 6,
            "playlistActions": true
        }
    }
}